// Firestore security rules for the recipe review system
// (yourwellnessgirly-4c224)
//
// This file is the REFERENCE copy — rules are actually deployed via the
// Firebase console (Firestore Database → Rules). If the deployed rules
// ever differ from this file, this file wins: re-paste it in the console.
//
// Design notes:
// - reviews:          publicly readable, create-only, strict field allowlist
// - review_contacts:  write-only from the client (emails are NEVER publicly
//                     readable — export them via the Firebase console only)
// - No update/delete from clients anywhere. Moderation = deleting docs
//   directly in the console, which bypasses these rules.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if
        // Field allowlist — no extra/unknown fields can be attached
        request.resource.data.keys().hasOnly(['recipeSlug', 'rating', 'comment', 'name', 'timestamp']) &&
        request.resource.data.keys().hasAll(['recipeSlug', 'rating', 'comment', 'name', 'timestamp']) &&
        request.resource.data.recipeSlug is string &&
        request.resource.data.recipeSlug.size() >= 1 &&
        request.resource.data.recipeSlug.size() <= 100 &&
        request.resource.data.rating is int &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5 &&
        request.resource.data.name is string &&
        request.resource.data.name.size() >= 2 &&
        request.resource.data.name.size() <= 60 &&
        request.resource.data.comment is string &&
        request.resource.data.comment.size() >= 10 &&
        request.resource.data.comment.size() <= 2000 &&
        // Must be serverTimestamp() — clients can't spoof dates to sort first
        request.resource.data.timestamp == request.time;
      allow update, delete: if false;
    }

    match /review_contacts/{contactId} {
      // Write-only: nobody can read emails through the public API
      allow read, update, delete: if false;
      allow create: if
        request.resource.data.keys().hasOnly(['email', 'subscribedToList', 'timestamp']) &&
        request.resource.data.keys().hasAll(['email', 'subscribedToList', 'timestamp']) &&
        request.resource.data.email is string &&
        request.resource.data.email.size() >= 5 &&
        request.resource.data.email.size() <= 120 &&
        request.resource.data.email.matches('.+@.+[.].+') &&
        request.resource.data.subscribedToList is bool &&
        request.resource.data.timestamp == request.time;
    }

    // Everything else: locked
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
